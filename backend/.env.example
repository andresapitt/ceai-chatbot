# Set these in the Vercel dashboard (Project, Settings, Environment Variables).
# For local testing with `vercel dev`, copy this file to .env and fill it in.
# .env is git-ignored, so the key never reaches GitHub.

GEMINI_API_KEY=your-api-key-here

# The single browser origin allowed to call this backend.
# Set to your GitHub Pages URL, no trailing slash.
ALLOWED_ORIGIN=https://andresapitt.github.io
